{
  "name": "app-evidencias",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "node scripts/run-next-cli.mjs dev",
    "dev:frontend": "node scripts/run-next-cli.mjs dev",
    "dev:backend": "node scripts/ensure-api-env.mjs && node scripts/run-dev-api.mjs",
    "dev:local": "node scripts/dev-local.mjs",
    "dev:api": "node scripts/ensure-api-env.mjs && node scripts/run-dev-api.mjs",
    "build": "node scripts/build-frontend.mjs && node scripts/sync-root-public.mjs",
    "start": "node scripts/run-next-cli.mjs start",
    "lint": "node scripts/run-next-cli.mjs lint",
    "docker:postgres": "docker compose up -d"
  },
  "dependencies": {
    "next": "16.2.4",
    "react": "19.2.0",
    "react-dom": "19.2.0"
  },
  "devDependencies": {
    "@types/node": "24.6.0",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "typescript": "5.9.3"
  }
}
