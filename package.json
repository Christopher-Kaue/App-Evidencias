{
  "name": "app-evidencias",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "npm --prefix web run dev",
    "dev:api": "node scripts/ensure-api-env.mjs && node scripts/run-dev-api.mjs",
    "dev:local": "node scripts/ensure-api-env.mjs && concurrently -k -n \"php,next\" -c \"magenta,cyan\" \"node scripts/run-dev-api.mjs\" \"npm run dev\"",
    "build": "npm --prefix web run build && node scripts/sync-root-public.mjs",
    "start": "npm --prefix web run start",
    "lint": "npm --prefix web run lint"
  },
  "dependencies": {
    "next": "16.2.4",
    "react": "19.2.0",
    "react-dom": "19.2.0"
  },
  "devDependencies": {
    "@types/node": "24.6.0",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "concurrently": "9.2.1",
    "typescript": "5.9.3"
  }
}
