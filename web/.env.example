# Opcional: URL absoluta do backend PHP (https, sem barra final).
# Obrigatoria em deploy preview na Vercel. Em producao, se o PHP estiver em
# MEUAPP-api.vercel.app e o Next em MEUAPP.vercel.app, pode omitir.
# NEXT_PUBLIC_API_BASE_URL=https://seu-projeto-api.vercel.app

# Alternativa: apenas o host da API (com ou sem https://).
# NEXT_PUBLIC_API_HOST=meu-projeto-api.vercel.app
