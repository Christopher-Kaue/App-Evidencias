# URL absoluta do backend PHP (https, sem barra final). Local padrao (repo):
#   http://127.0.0.1:9999  — com `npm run dev:api` ou `npm run dev:local`
# XAMPP (htdocs/app-evidencias):
# NEXT_PUBLIC_API_BASE_URL=http://localhost/app-evidencias
#
# Na Vercel o build pode usar proxy same-origin (web/vercel.json rewrites /api-proxy).
# O destination do rewrite deve ser o mesmo URL do projeto PHP no browser + /api/:path*
# Desative Deployment Protection no projeto PHP se houver 403 na borda.
# Modo direto (CORS): NEXT_PUBLIC_API_VIA_PROXY=0 e
# NEXT_PUBLIC_API_BASE_URL=https://seu-php.vercel.app

# Alternativa ao BASE_URL: apenas o host da API (com ou sem https://).
# NEXT_PUBLIC_API_HOST=meu-projeto-api.vercel.app
