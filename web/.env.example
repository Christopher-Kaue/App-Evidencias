# URL absoluta do backend PHP (https, sem barra final).
# Local (XAMPP): descomente a linha abaixo.
# NEXT_PUBLIC_API_BASE_URL=http://localhost/app-evidencias
#
# Na Vercel, este repositorio define a URL em web/vercel.json (env) para todos
# os deploys. Para outro fork/time, altere la ou sobrescreva no painel do projeto.

# Alternativa ao BASE_URL: apenas o host da API (com ou sem https://).
# NEXT_PUBLIC_API_HOST=meu-projeto-api.vercel.app
