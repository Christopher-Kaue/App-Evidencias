# URL absoluta do backend PHP (https, sem barra final). Local (XAMPP):
# NEXT_PUBLIC_API_BASE_URL=http://localhost/app-evidencias
#
# Na Vercel o build ativa proxy same-origin (web/vercel.json rewrites /api-proxy).
# Ajuste o destino em web/vercel.json se o host do PHP mudar.
# Para desativar o proxy e usar CORS direto: NEXT_PUBLIC_API_VIA_PROXY=0 e
# NEXT_PUBLIC_API_BASE_URL=https://seu-php.vercel.app

# Alternativa ao BASE_URL: apenas o host da API (com ou sem https://).
# NEXT_PUBLIC_API_HOST=meu-projeto-api.vercel.app
