# Opcao A — recomendada na Vercel / Neon / Supabase (uma unica variavel):
# DATABASE_URL=postgresql://usuario:senha@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require
#
# Opcao B — variaveis separadas (local ou servidores classicos):
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=app_evidencias
DB_USER=postgres
DB_PASS=postgres

# Docker Compose (raiz): docker compose up -d — Postgres usa usuario postgres / senha postgres neste exemplo.
# Se o volume ja existia antes do schema, rode na raiz: npm run docker:schema

# Mais de um PostgreSQL instalado: a porta padrao e definida em postgresql.conf (neste projeto esperamos PG na porta acima).

# Projeto PHP na Vercel: copie estas variaveis para Environment Variables (este .env e apenas local).
# OBRIGATORIO: criar as tabelas antes do login — cole database/schema_postgres.sql no SQL Editor do Neon (ou psql).
# Prioridade de ligacao: DATABASE_URL > DB_HOST / DB_NAME / ...
# DB_SSL=1 — sslmode=require quando usa DB_* sem DATABASE_URL.

# URL publica da API (opcional) — usada em upload.php para montar o link do arquivo
# PUBLIC_APP_URL=https://seu-projeto-api.vercel.app
