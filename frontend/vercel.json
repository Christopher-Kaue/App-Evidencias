{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "out",
  "rewrites": [
    {
      "source": "/api-proxy/:path*",
      "destination": "https://api-one-ashen-16.vercel.app/api/:path*"
    }
  ]
}
