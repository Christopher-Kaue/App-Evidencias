# Same-origin /api-proxy → PHP no Next dev (evita falhas cruzando localhost vs 127.0.0.1).
NEXT_PUBLIC_API_VIA_PROXY=1
DEV_PHP_ORIGIN=http://127.0.0.1:9999

# Modo direto (fetch cross-origin para o PHP): desative o proxy e use URL absoluta:
# NEXT_PUBLIC_API_VIA_PROXY=0
# NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:9999
