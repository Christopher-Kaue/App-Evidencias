DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=app_evidencias
DB_USER=root
DB_PASS=

# Projeto PHP na Vercel: use Environment Variables no painel (este .env e apenas local/XAMPP).
# Importe o script database/schema_cloud.sql no MySQL da nuvem antes de testar o login.
# Muitos servidores exigem DB_SSL=1 (Aiven, Azure, etc.); no Vercel a conexao e de fora do teu PC.
# DB_SSL=1
# DB_SSL_CA=/caminho/para/ca.pem

# URL publica da API (opcional) — usada em upload.php para montar o link do arquivo
# PUBLIC_APP_URL=https://seu-projeto-api.vercel.app
